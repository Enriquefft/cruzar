# Cruzar — environment variables (MVP 0)
# Copy this file to .env and fill in. Each key is documented with where to obtain it.

# ============================================================================
# Database — Neon Postgres
# ============================================================================
# Create a project at https://console.neon.tech, grab the connection string.
# Use the pooled connection string for serverless (apps/web); apps/operator-scripts/ use
# either but the pooled works for both.
DATABASE_URL=postgres://user:pass@host.neon.tech/cruzar?sslmode=require

# ============================================================================
# Auth — Better Auth (email + magic link)
# ============================================================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of the app. https://cruzarapp.com in prod, http://localhost:3000 in dev.
BETTER_AUTH_URL=http://localhost:3000
# Public (browser-exposed) base URL for `better-auth/client`. Must match
# BETTER_AUTH_URL on the same deployment. Optional — the client falls back to
# window.location.origin at runtime when unset.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ============================================================================
# Email — Resend (transactional)
# ============================================================================
# Create an API key at https://resend.com. Verify cruzarapp.com domain with
# DKIM + SPF + DMARC records before sending any magic link. First magic link
# MUST land in Primary inbox (not Spam/Promotions) on an external Gmail test.
RESEND_API_KEY=
# Full From header. Format: 'Display Name <mailbox@domain>'. Domain must be
# DKIM/SPF/DMARC-verified in Resend before first send.
RESEND_FROM_EMAIL='VendeKit <noreply@vendekit.com>'

# ============================================================================
# LLM — Z.ai (OpenAI-compatible GLM models)
# ============================================================================
# Z.ai exposes an OpenAI-compatible API over the base URL below. Two tiers
# used across the codebase: strong (synthesis, assessment, per-JD CV tailor)
# and weak (fast classifications, batch question generation, inbox triage).
# See https://z.ai for the API key + model list.
AI_API_KEY=
AI_BASE_URL=https://api.z.ai/api/coding/paas/v4
AI_STRONG_MODEL=glm-5.1
AI_WEAK_MODEL=glm-5-turbo

# ============================================================================
# Object storage — Cloudflare R2
# ============================================================================
# Create a bucket named "cruzar" and apply CORS via:
#   bun run apps/operator-scripts/r2-setup.ts            # dry run (drift report)
#   bun run apps/operator-scripts/r2-setup.ts --apply    # creates bucket + applies CORS
# Canonical CORS rules live in apps/web/r2-cors.json (PUT+GET from
# https://cruzarapp.com and http://localhost:3000). Optional: CNAME
# cdn.cruzarapp.com → the bucket for public reads (set via Cloudflare dashboard).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cruzar
R2_PUBLIC_URL=https://cdn.cruzarapp.com

# ============================================================================
# Observability — PostHog (product analytics + session replay + error tracking)
# ============================================================================
# Create project at https://us.posthog.com (US) or https://eu.posthog.com (EU).
# Project API key is "public" — safe to expose to the browser. Both the browser
# SDK (instrumentation-client.ts) and the server SDK (instrumentation.ts) read
# the same NEXT_PUBLIC_POSTHOG_KEY, so one key powers pageviews, replays, and
# Next 16 onRequestError captures. Host must match the region where the project
# was created.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# Operator allowlist (emails permitted to run operator skills + escape hatches)
# ============================================================================
# Comma-separated emails. Checked by apps/operator-scripts/sql.ts on --write and by any
# internal-only route that may land post-MVP 0.
OPERATOR_EMAILS=miura@cruzarapp.com,enrique@cruzarapp.com

# ============================================================================
# Runtime
# ============================================================================
NODE_ENV=development
