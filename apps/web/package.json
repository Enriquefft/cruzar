    "better-auth": "1.6.4",
    "drizzle-orm": "0.45.2",
    "next": "16.2.3",
    "postgres": "3.4.9",
    "posthog-js": "1.369.2",
    "posthog-node": "5.29.2",
    "react": "19.2.4",
